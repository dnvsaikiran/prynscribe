rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profile Rules
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Allow initial creation during onboarding
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Restricted Updates: Users cannot manually change their own premium status or region once validated
      allow update: if request.auth != null && request.auth.uid == userId
                    && (
                      // If onboarding isn't complete, they can set their region/goal
                      resource.data.onboardingComplete == false
                      || 
                      // If onboarding IS complete, they cannot touch 'isPremium', 'plan', or 'region'
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isPremium', 'plan', 'region'])
                    );
      
      match /lectures/{lectureId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /outputs/{lectureId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
